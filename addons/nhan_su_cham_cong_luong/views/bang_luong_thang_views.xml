<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_bang_luong_thang_tree" model="ir.ui.view">
        <field name="name">bang.luong.thang.tree</field>
        <field name="model">bang.luong.thang</field>
        <field name="arch" type="xml">
            <tree string="Bảng lương theo tháng"
                  decoration-info="trang_thai=='draft'"
                  decoration-warning="trang_thai=='calculated'"
                  decoration-success="trang_thai=='confirmed'"
                  decoration-muted="trang_thai=='paid'">
                <field name="employee_id"/>
                <field name="thang"/>
                <field name="nam"/>
                <field name="luong_co_ban" widget="monetary"/>
                <field name="tong_ngay_cong"/>
                <field name="so_ngay_cong_chuan"/>
                <field name="ty_le_cong" widget="percentage"/>
                <field name="tong_gio_tang_ca_thuong" string="TC thường (h)"/>
                <field name="tong_gio_tang_ca_cuoi_tuan" string="TC cuối tuần (h)"/>
                <field name="so_lan_vi_pham" string="Vi phạm"/>
                <field name="luong_thuc_lanh" widget="monetary"/>
                <field name="trang_thai" widget="badge"
                       decoration-info="trang_thai=='draft'"
                       decoration-warning="trang_thai=='calculated'"
                       decoration-success="trang_thai=='confirmed'"
                       decoration-muted="trang_thai=='paid'"/>
                <field name="currency_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_bang_luong_thang_form" model="ir.ui.view">
        <field name="name">bang.luong.thang.form</field>
        <field name="model">bang.luong.thang</field>
        <field name="arch" type="xml">
            <form string="Bảng lương theo tháng">
                <header>
                    <button name="action_calculate" string="Tính lương" type="object"
                            class="btn-primary" attrs="{'invisible': [('trang_thai', '!=', 'draft')]}"/>
                    <button name="action_confirm" string="Xác nhận" type="object"
                            class="btn-primary" attrs="{'invisible': [('trang_thai', '!=', 'calculated')]}"/>
                    <button name="action_mark_paid" string="Đánh dấu đã trả" type="object"
                            class="btn-secondary" attrs="{'invisible': [('trang_thai', '!=', 'confirmed')]}"/>
                    <button name="action_reset_to_draft" string="Đưa về nháp" type="object"
                            attrs="{'invisible': [('trang_thai', '=', 'draft')]}"/>
                    <field name="trang_thai" widget="statusbar" statusbar_visible="draft,calculated,confirmed,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="ten_bang_luong" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Thông tin cơ bản">
                            <field name="employee_id" attrs="{'readonly': [('trang_thai', '!=', 'draft')]}"/>
                            <field name="thang" attrs="{'readonly': [('trang_thai', '!=', 'draft')]}"/>
                            <field name="nam" attrs="{'readonly': [('trang_thai', '!=', 'draft')]}"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Liên kết">
                            <field name="bang_cham_cong_id" readonly="1"/>
                            <field name="hr_contract_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Dữ liệu chấm công">
                            <field name="so_ngay_cong_chuan" readonly="1"/>
                            <field name="tong_ngay_cong" readonly="1"/>
                            <field name="so_ngay_lam_viec" readonly="1"/>
                            <field name="tong_gio_lam_viec" widget="float_time" readonly="1"/>
                            <field name="ty_le_cong" widget="percentage" readonly="1"/>
                        </group>
                        <group string="Tính lương">
                            <field name="luong_co_ban" widget="monetary" readonly="1"/>
                            <field name="luong_theo_gio" widget="monetary" readonly="1"/>
                            <field name="luong_theo_ngay_cong" widget="monetary" readonly="1"/>
                            <field name="phu_cap_khac" widget="monetary"
                                   attrs="{'readonly': [('trang_thai', 'in', ['confirmed', 'paid'])]}"/>
                            <field name="khau_tru_khac" widget="monetary"
                                   attrs="{'readonly': [('trang_thai', 'in', ['confirmed', 'paid'])]}"/>
                        </group>
                    </group>
                    <group>
                        <group string="Tăng ca" attrs="{'invisible': [('tong_gio_tang_ca_thuong', '=', 0), ('tong_gio_tang_ca_cuoi_tuan', '=', 0)]}">
                            <field name="tong_gio_tang_ca_thuong" readonly="1"/>
                            <field name="tong_gio_tang_ca_cuoi_tuan" readonly="1"/>
                            <field name="tien_tang_ca" widget="monetary" readonly="1"/>
                        </group>
                        <group string="Kỷ luật" attrs="{'invisible': [('so_lan_vi_pham', '=', 0)]}">
                            <field name="so_lan_vi_pham" readonly="1"/>
                            <field name="tong_phut_vi_pham" readonly="1"/>
                            <field name="tien_phat_ky_luat" widget="monetary" readonly="1"/>
                        </group>
                    </group>
                    <!-- Giảm trừ gia cảnh & Thuế TNCN -->
                    <group>
                        <group string="Giảm trừ gia cảnh (GTGC)">
                            <field name="so_nguoi_phu_thuoc" readonly="1"/>
                            <field name="tong_giam_tru_gia_canh" widget="monetary" readonly="1"/>
                            <field name="tien_bao_hiem" widget="monetary" readonly="1"/>
                            <field name="thu_nhap_chiu_thue" widget="monetary" readonly="1"/>
                            <field name="thu_nhap_tinh_thue" widget="monetary" readonly="1"/>
                            <field name="thue_tncn" widget="monetary" readonly="1"/>
                        </group>
                        <group string="Tổng kết">
                            <field name="luong_thuc_lanh" widget="monetary" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Chi tiết phiếu lương" name="chi_tiet_luong">
                            <field name="line_ids"
                                   attrs="{'readonly': [('trang_thai', 'in', ['confirmed', 'paid'])]}">
                                <tree string="Chi tiết" editable="bottom"
                                      decoration-success="loai=='cong'"
                                      decoration-danger="loai=='tru'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="loai"/>
                                    <field name="so_tien" widget="monetary"/>
                                    <field name="ghi_chu"/>
                                    <field name="currency_id" invisible="1"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="thuc_lanh_chi_tiet" widget="monetary" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                    <group>
                        <field name="ghi_chu" attrs="{'readonly': [('trang_thai', 'in', ['confirmed', 'paid'])]}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_bang_luong_thang_search" model="ir.ui.view">
        <field name="name">bang.luong.thang.search</field>
        <field name="model">bang.luong.thang</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm bảng lương">
                <field name="employee_id"/>
                <field name="thang"/>
                <field name="nam"/>
                <filter string="Tháng hiện tại" name="thang_hien_tai"
                        domain="[('thang', '=', context_today().month), ('nam', '=', context_today().year)]"/>
                <filter string="Nháp" name="draft" domain="[('trang_thai', '=', 'draft')]"/>
                <filter string="Đã tính" name="calculated" domain="[('trang_thai', '=', 'calculated')]"/>
                <filter string="Đã xác nhận" name="confirmed" domain="[('trang_thai', '=', 'confirmed')]"/>
                <filter string="Đã thanh toán" name="paid" domain="[('trang_thai', '=', 'paid')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Nhân viên" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Tháng" name="group_thang" context="{'group_by': 'thang'}"/>
                    <filter string="Năm" name="group_nam" context="{'group_by': 'nam'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_bang_luong_thang" model="ir.actions.act_window">
        <field name="name">Bảng lương theo tháng</field>
        <field name="res_model">bang.luong.thang</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_bang_luong_thang_search"/>
        <field name="context">{'search_default_thang_hien_tai': 1}</field>
    </record>
</odoo>
